{
  "name": "@gtryp/chess-cli",
  "version": "0.2.0",
  "description": "Interactive local pass-and-play chess TUI for the terminal.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GabrielGenkov/chess-cli.git"
  },
  "bugs": {
    "url": "https://github.com/GabrielGenkov/chess-cli/issues"
  },
  "homepage": "https://github.com/GabrielGenkov/chess-cli#readme",
  "keywords": [
    "chess",
    "cli",
    "terminal",
    "tui",
    "game"
  ],
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "chess-cli": "./dist/main.js"
  },
  "scripts": {
    "build": "tsup",
    "ci": "npm run typecheck && npm test && npm run build",
    "dev": "tsx src/main.ts",
    "prepublishOnly": "npm run ci",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "chess.js": "^1.4.0",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
